// ╔═══════════════════════════════════════════════════════════════════╗
// ║  COACH DU DIMANCHE V2 — Firestore Security Rules                  ║
// ║  Projet Firebase : arbitre-sport                                  ║
// ║  À déployer : console Firebase → Firestore → Règles → Publier     ║
// ║  ou  firebase deploy --only firestore:rules                       ║
// ╚═══════════════════════════════════════════════════════════════════╝
//
// PHASE C — C1 (socle). Deux zones :
//
//  1. Modèle AUTORISÉ (clubs / teams / players / memberships / invites) :
//     accès imposé côté serveur. Un utilisateur ne lit/écrit un club que
//     s'il possède une `membership` pour ce club. Infranchissable, même
//     via les outils développeur du navigateur.
//
//  2. Collections existantes (cdd_v2_*, shared_teams) : conservées TELLES
//     QUELLES. La synchro convoc/vote/statuts tourne avec un voterId
//     anonyme — on n'y touche pas en C1 pour ne rien casser. Leur
//     durcissement viendra en C3/C4 quand les écrans seront branchés sur
//     les memberships.
//
// CONVENTION CLÉ : l'ID d'un document `memberships` est `{uid}_{clubId}`.
// Cela permet aux règles de retrouver une membership par `get()` direct
// (Firestore ne permet pas de requêter une collection depuis une règle).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ Helpers — schéma (existants) ═══════════════════════════════
    function isString(v)  { return v is string;  }
    function isNumber(v)  { return v is number;  }
    function isBool(v)    { return v is bool;    }
    function isMap(v)     { return v is map;     }
    function strLen(v, max) { return isString(v) && v.size() <= max; }
    function validStatus(s) {
      return s in ['active', 'rest', 'injured', 'suspended', 'reserve'];
    }

    // ═══ Helpers — authentification & autorisation (Phase C) ════════
    function isSignedIn() { return request.auth != null; }
    function myUid()      { return request.auth.uid; }
    function myEmail() {
      return (isSignedIn() && request.auth.token.email != null)
        ? request.auth.token.email.lower() : '';
    }
    // Admin = super-utilisateur. Fiable depuis qu'une vraie auth existe
    // (impossible de "se faire passer" pour cet email sans la boîte Gmail).
    function isAdmin() {
      return isSignedIn() && myEmail() == 'archi.tech.fr@gmail.com';
    }

    // Membership de l'utilisateur courant pour un club (id = {uid}_{clubId}).
    function membershipPath(clubId) {
      return /databases/$(database)/documents/memberships/$(myUid() + '_' + clubId);
    }
    function hasMembership(clubId) {
      return isSignedIn() && exists(membershipPath(clubId));
    }
    function membershipRole(clubId) {
      return get(membershipPath(clubId)).data.role;
    }
    // Lecture d'un club : admin, ou membership quelconque sur ce club.
    function canReadClub(clubId) {
      return isAdmin() || hasMembership(clubId);
    }
    // Écriture des données d'un club : admin, ou membership coach/owner.
    // Les rôles adjoint/parent/joueur/lecteur sont en LECTURE SEULE.
    function canEditClub(clubId) {
      return isAdmin() ||
        (hasMembership(clubId) &&
         membershipRole(clubId) in ['owner', 'coach']);
    }

    // ═══ /clubs/{clubId} ════════════════════════════════════════════
    match /clubs/{clubId} {
      allow read:   if canReadClub(clubId);
      // Création d'un club = création d'un compte coach → réservé à l'admin
      // (exigence : "seul l'admin donne accès à un compte coach").
      allow create: if isAdmin()
        && request.resource.data.createdBy == myUid()
        && request.resource.data.size() <= 20;
      allow update: if canEditClub(clubId) && request.resource.data.size() <= 20;
      allow delete: if isAdmin();
    }

    // ═══ /teams/{teamId} ════════════════════════════════════════════
    match /teams/{teamId} {
      allow read:   if canReadClub(resource.data.clubId);
      allow create: if canEditClub(request.resource.data.clubId)
        && isString(request.resource.data.clubId)
        && request.resource.data.size() <= 40;
      // clubId immuable après création.
      allow update: if canEditClub(resource.data.clubId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.size() <= 40;
      allow delete: if canEditClub(resource.data.clubId);
    }

    // ═══ /players/{playerId} ════════════════════════════════════════
    match /players/{playerId} {
      allow read:   if canReadClub(resource.data.clubId);
      allow create: if canEditClub(request.resource.data.clubId)
        && isString(request.resource.data.clubId)
        && request.resource.data.size() <= 80;
      allow update: if canEditClub(resource.data.clubId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.size() <= 80;
      allow delete: if canEditClub(resource.data.clubId);
    }

    // ═══ /memberships/{membershipId}  (id = {uid}_{clubId}) ═════════
    // Table d'autorisation — cœur du système.
    match /memberships/{membershipId} {
      // Lecture : la sienne, ou celles de son club si on est coach, ou admin.
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.uid == myUid() ||
        canEditClub(resource.data.clubId)
      );
      // Création :
      //  - l'id DOIT être {uid}_{clubId} (cohérence + unicité),
      //  - un rôle coach/owner/admin ne peut être attribué QUE par l'admin,
      //  - un coach peut rattacher des rôles non-coach à SON club,
      //  - une membership 'parent' DOIT porter un playerId (lien obligatoire).
      allow create: if isSignedIn()
        && membershipId == request.resource.data.uid + '_' + request.resource.data.clubId
        && request.resource.data.size() <= 15
        && (
          isAdmin() ||
          ( canEditClub(request.resource.data.clubId)
            && !(request.resource.data.role in ['owner', 'admin', 'coach']) )
        )
        && ( request.resource.data.role != 'parent'
             || request.resource.data.playerId is string );
      allow update: if isAdmin() || canEditClub(resource.data.clubId);
      allow delete: if isAdmin() || canEditClub(resource.data.clubId);
    }

    // ═══ /invites/{token} ═══════════════════════════════════════════
    // Liens d'invitation. Le token (id du doc) est un secret partagé.
    match /invites/{token} {
      // Lecture : tout utilisateur signé (nécessaire pour consommer le lien).
      allow read: if isSignedIn();
      // Création : coach/owner du club. Un coach NE PEUT PAS inviter un
      // coach (réservé à l'admin) — exigence produit.
      allow create: if isSignedIn()
        && canEditClub(request.resource.data.clubId)
        && request.resource.data.size() <= 15
        && ( isAdmin() ||
             !(request.resource.data.role in ['owner', 'admin', 'coach']) );
      // Mise à jour : le coach du club, OU l'invité qui consomme le lien
      // (passage consumed false→true en s'attribuant consumedBy).
      allow update: if isSignedIn() && (
        canEditClub(resource.data.clubId) ||
        ( resource.data.consumed == false
          && request.resource.data.consumed == true
          && request.resource.data.consumedBy == myUid() )
      );
      allow delete: if isAdmin() || canEditClub(resource.data.clubId);
    }

    // ═══════════════════════════════════════════════════════════════
    //  COLLECTIONS EXISTANTES — conservées telles quelles (ne pas casser)
    // ═══════════════════════════════════════════════════════════════

    // ─── /cdd_v2_players/{playerId} ────────────────────────────────
    // Statuts joueurs + métadonnées (blessure, suspension, indispo, etc.)
    match /cdd_v2_players/{playerId} {
      allow read: if true;

      allow create, update: if
        request.resource.data.keys().hasAll(['playerId','teamId','status'])
        && isString(request.resource.data.playerId)
        && isString(request.resource.data.teamId)
        && validStatus(request.resource.data.status)
        && strLen(request.resource.data.playerId, 80)
        && strLen(request.resource.data.teamId,   80)
        && request.resource.data.playerId == playerId
        && (!('statusMeta' in request.resource.data) || isMap(request.resource.data.statusMeta))
        && (!('statusUpdatedBy' in request.resource.data) || strLen(request.resource.data.statusUpdatedBy, 60));

      allow update: if request.resource.data.teamId == resource.data.teamId;
      allow delete: if false;
    }

    // ─── /cdd_v2_convoc/{matchId} ──────────────────────────────────
    match /cdd_v2_convoc/{matchId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['responses'])
        && (!('responses' in request.resource.data) || isMap(request.resource.data.responses));
    }

    // ─── /cdd_v2_votes/{matchId} ───────────────────────────────────
    match /cdd_v2_votes/{matchId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['voters'])
        && (!('voters' in request.resource.data) || isMap(request.resource.data.voters));
    }

    // ─── /cdd_v2_matches/{matchId} ─────────────────────────────────
    match /cdd_v2_matches/{matchId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['id','teamA','teamB','status','events'])
        && request.resource.data.size() <= 50;
    }

    // ─── /shared_teams/{token} ─────────────────────────────────────
    match /shared_teams/{token} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['payload'])
        && isMap(request.resource.data.payload)
        && isMap(request.resource.data.payload.team)
        && strLen(request.resource.data.payload.team.name, 200)
        && request.resource.data.size() <= 30;
    }

    // ─── Bloque tout le reste par défaut ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
