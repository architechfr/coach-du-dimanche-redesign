// ╔═══════════════════════════════════════════════════════════════════╗
// ║  COACH DU DIMANCHE V2 — Firestore Security Rules                  ║
// ║  Projet Firebase : arbitre-sport                                  ║
// ║  À déployer : console Firebase → Firestore → Règles → Publier     ║
// ╚═══════════════════════════════════════════════════════════════════╝
//
// PHASE D — modèle d'autorisation PAR ÉQUIPE & multi-rôles.
// Voir Version/V2/PHASE-D-PLAN.md pour la conception complète.
//
// ⚠️ Ces règles supposent le NOUVEAU schéma de membership (map `teams`).
// Elles vont de pair avec roles.js / firebase-sync.js D3-D6 et la migration
// D5 — ne PAS déployer seules tant que l'app n'écrit pas le nouveau format.
//
// CONVENTION CLÉ : l'ID d'un document `memberships` est `{uid}_{clubId}`.
// Cela permet aux règles de retrouver une membership par `get()` direct
// (Firestore ne permet pas de requêter une collection depuis une règle).
//
// MODÈLE memberships/{uid}_{clubId} :
//   { uid, email, clubId,
//     clubRole,                       // standing club-level (dénormalisé)
//     teams: { "{teamId}": { role, playerId } },   // un rôle PAR ÉQUIPE
//     inviteToken?, createdBy, createdAt, updatedAt }
//   role ∈ owner | admin | coach | adjoint | parent | joueur | lecteur
//   Règle d'or : un rôle coach/owner/admin ne peut être posé QUE par l'admin
//   (ou par un coach principal déjà en place sur SON club). Jamais par lien.

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ Helpers — schéma (existants, collections cdd_v2_*) ═════════
    function isString(v)  { return v is string;  }
    function isNumber(v)  { return v is number;  }
    function isBool(v)    { return v is bool;    }
    function isMap(v)     { return v is map;     }
    function strLen(v, max) { return isString(v) && v.size() <= max; }
    function validStatus(s) {
      return s in ['active', 'rest', 'injured', 'suspended', 'reserve'];
    }

    // ═══ Helpers — authentification ═════════════════════════════════
    function isSignedIn() { return request.auth != null; }
    function myUid()      { return request.auth.uid; }
    function myEmail() {
      return (isSignedIn() && request.auth.token.email != null)
        ? request.auth.token.email.lower() : '';
    }
    // Admin = super-utilisateur. Fiable : impossible d'usurper cet email
    // sans posséder la boîte Gmail correspondante.
    function isAdmin() {
      return isSignedIn() && myEmail() == 'archi.tech.fr@gmail.com';
    }

    // ═══ Helpers — memberships (Phase D, modèle par équipe) ═════════
    function membershipPath(clubId) {
      return /databases/$(database)/documents/memberships/$(myUid() + '_' + clubId);
    }
    function hasMembership(clubId) {
      return isSignedIn() && exists(membershipPath(clubId));
    }
    function membershipData(clubId) {
      return get(membershipPath(clubId)).data;
    }
    // Standing club-level de l'utilisateur ('' si aucune membership).
    function clubRole(clubId) {
      return hasMembership(clubId) ? membershipData(clubId).clubRole : '';
    }
    // Rôle de l'utilisateur sur UNE équipe précise ('' si rien).
    function teamRole(clubId, teamId) {
      return (hasMembership(clubId)
              && ('teams' in membershipData(clubId))
              && (teamId in membershipData(clubId).teams))
        ? membershipData(clubId).teams[teamId].role : '';
    }

    // Lecture d'un club / d'une équipe : admin, ou membre du club.
    function canReadClub(clubId) {
      return isAdmin() || hasMembership(clubId);
    }
    // Gérer le club : créer des équipes, éditer le doc club (logo, infos).
    // Admin ou coach principal/owner (clubRole). Pas l'adjoint.
    function canManageClub(clubId) {
      return isAdmin() || clubRole(clubId) in ['owner', 'coach'];
    }
    // Éditer les DONNÉES d'une équipe (joueurs, compo) : admin, coach
    // principal OU adjoint DE CETTE ÉQUIPE. Parent/joueur/lecteur = non.
    function canEditTeam(clubId, teamId) {
      return isAdmin() || teamRole(clubId, teamId) in ['owner', 'coach', 'adjoint'];
    }
    // Supprimer une équipe : admin ou coach principal de cette équipe.
    function canManageTeam(clubId, teamId) {
      return isAdmin() || teamRole(clubId, teamId) in ['owner', 'coach'];
    }

    // ═══ Helpers — invitations ══════════════════════════════════════
    function invitePath(token) {
      return /databases/$(database)/documents/invites/$(token);
    }
    // Invitation exploitable : non consommée, non expirée, jamais un rôle
    // coach/owner/admin (ces comptes ne s'obtiennent pas par lien).
    function inviteValid(token) {
      let inv = get(invitePath(token)).data;
      return exists(invitePath(token))
        && inv.consumed == false
        && !(inv.role in ['owner', 'admin', 'coach'])
        && (!('expiresAt' in inv) || inv.expiresAt == null
            || request.time.toMillis() < inv.expiresAt);
    }
    // CRÉATION de membership depuis une invitation : la map `teams` ne
    // contient QUE l'équipe de l'invitation, au rôle de l'invitation.
    function createMatchesInvite(m) {
      let inv = get(invitePath(m.inviteToken)).data;
      return m.clubId == inv.clubId
        && m.teams is map
        && m.teams.size() == 1
        && (inv.teamId in m.teams)
        && m.teams[inv.teamId].role == inv.role
        && m.teams[inv.teamId].playerId == inv.playerId
        && !(m.clubRole in ['owner', 'admin', 'coach']);
    }
    // MISE À JOUR de membership depuis une invitation : on AJOUTE l'équipe
    // de l'invitation, on garde toutes les anciennes, pas d'escalade coach.
    function updateMatchesInvite(old, m) {
      let inv = get(invitePath(m.inviteToken)).data;
      return m.clubId == old.clubId
        && m.uid == old.uid
        && inv.clubId == m.clubId
        && m.teams is map
        && (inv.teamId in m.teams)
        && m.teams[inv.teamId].role == inv.role
        && m.teams[inv.teamId].playerId == inv.playerId
        && !(m.clubRole in ['owner', 'admin', 'coach'])
        && m.teams.size() == old.teams.size() + 1
        && m.teams.keys().hasAll(old.teams.keys());
    }
    // Matrice d'invitation — MIROIR de roles.js → INVITE_MATRIX. Le rôle
    // de l'invitant est lu SUR L'ÉQUIPE cible de l'invitation.
    //  owner / coach / admin     → adjoint, parent, joueur, lecteur
    //  adjoint / joueur / parent → parent, joueur, lecteur
    //  lecteur                   → personne
    function canInviteRole(clubId, teamId, target) {
      let r = isAdmin() ? 'admin' : teamRole(clubId, teamId);
      return r == 'admin'
        || (r in ['owner', 'coach']
            && target in ['adjoint', 'parent', 'joueur', 'lecteur'])
        || (r in ['adjoint', 'joueur', 'parent']
            && target in ['parent', 'joueur', 'lecteur']);
    }

    // ═══ /clubs/{clubId} ════════════════════════════════════════════
    match /clubs/{clubId} {
      allow read:   if canReadClub(clubId);
      // Création d'un club : réservé à l'admin (il vend l'app + la mise en
      // place). L'auto-inscription payante d'un coach viendra plus tard.
      allow create: if isAdmin()
        && request.resource.data.createdBy is string
        && request.resource.data.size() <= 30;
      // Éditer le doc club (logo, infos, description, palmarès, mot du président,
      // année fondation, etc.) : admin ou coach principal. Limite à 30 champs
      // pour accommoder les enrichissements de fiche club.
      allow update: if canManageClub(clubId) && request.resource.data.size() <= 30;
      allow delete: if isAdmin();
    }

    // ═══ /teams/{teamId} ════════════════════════════════════════════
    match /teams/{teamId} {
      allow read:   if canReadClub(resource.data.clubId);
      // Créer une équipe : admin ou coach principal du club.
      allow create: if canManageClub(request.resource.data.clubId)
        && isString(request.resource.data.clubId)
        && request.resource.data.size() <= 40;
      // clubId immuable après création.
      allow update: if canEditTeam(resource.data.clubId, teamId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.size() <= 40;
      allow delete: if canManageTeam(resource.data.clubId, teamId);
    }

    // ═══ /players/{playerId} ════════════════════════════════════════
    match /players/{playerId} {
      allow read:   if canReadClub(resource.data.clubId);
      allow create: if canEditTeam(request.resource.data.clubId,
                                   request.resource.data.teamId)
        && isString(request.resource.data.clubId)
        && isString(request.resource.data.teamId)
        && request.resource.data.size() <= 80;
      // clubId et teamId immuables après création.
      allow update: if canEditTeam(resource.data.clubId, resource.data.teamId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.size() <= 80;
      allow delete: if canEditTeam(resource.data.clubId, resource.data.teamId);
    }

    // ═══ /memberships/{membershipId}  (id = {uid}_{clubId}) ═════════
    // Table d'autorisation — cœur du système.
    match /memberships/{membershipId} {
      // Lecture : la sienne, celles de son club si on est coach, ou admin.
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.uid == myUid() ||
        canManageClub(resource.data.clubId)
      );
      // Création :
      //  - id imposé {uid}_{clubId},
      //  - admin : tout (assigne les coachs principaux),
      //  - coach principal du club : rattacher des membres NON-coach,
      //  - invité : crée SA propre membership via un token valide.
      allow create: if isSignedIn()
        && membershipId == request.resource.data.uid + '_' + request.resource.data.clubId
        && request.resource.data.teams is map
        && request.resource.data.size() <= 16
        && (
          isAdmin() ||
          ( canManageClub(request.resource.data.clubId)
            && !(request.resource.data.clubRole in ['owner', 'admin', 'coach']) ) ||
          ( request.resource.data.uid == myUid()
            && request.resource.data.inviteToken is string
            && exists(invitePath(request.resource.data.inviteToken))
            && inviteValid(request.resource.data.inviteToken)
            && createMatchesInvite(request.resource.data) )
        );
      // Mise à jour :
      //  - admin, ou coach principal du club (gestion du roster),
      //  - invité : ajoute UNE équipe à SA membership via un token valide.
      allow update: if isSignedIn()
        && request.resource.data.size() <= 16
        && (
          isAdmin() ||
          canManageClub(resource.data.clubId) ||
          ( request.resource.data.uid == myUid()
            && request.resource.data.inviteToken is string
            && exists(invitePath(request.resource.data.inviteToken))
            && inviteValid(request.resource.data.inviteToken)
            && updateMatchesInvite(resource.data, request.resource.data) )
        );
      allow delete: if isAdmin() || canManageClub(resource.data.clubId);
    }

    // ═══ /invites/{token} ═══════════════════════════════════════════
    // Liens d'invitation. Le token (id du doc) est un secret partagé.
    match /invites/{token} {
      // Lecture : PUBLIQUE. Le token agit lui-même comme secret — l'invité
      // ne peut consommer un lien que s'il connaît le token (envoyé via
      // WhatsApp/SMS par le coach). Lecture publique permet d'afficher
      // une vraie page de validation AVANT login (« Tu rejoins FCMH comme
      // parent de Djibril TRAORE — Connecte-toi pour accepter »).
      allow read: if true;
      // Création : selon la matrice — le rôle de l'invitant est lu sur
      // l'ÉQUIPE cible. canInviteRole exige une membership → pas de lien
      // sans rattachement à cette équipe. Limite 18 champs (place pour
      // clubName / teamName / playerName stockés à la création — sert
      // à afficher la page de validation sans dépendre d'autres lectures).
      allow create: if isSignedIn()
        && request.resource.data.size() <= 18
        && canInviteRole(request.resource.data.clubId,
                         request.resource.data.teamId,
                         request.resource.data.role);
      // Mise à jour : coach principal du club, OU l'invité qui consomme
      // le lien (passage consumed false→true en s'attribuant consumedBy).
      allow update: if isSignedIn() && (
        canManageClub(resource.data.clubId) ||
        ( resource.data.consumed == false
          && request.resource.data.consumed == true
          && request.resource.data.consumedBy == myUid() )
      );
      // Suppression (révocation) : admin, coach principal du club, ou
      // l'auteur du lien lui-même.
      allow delete: if isAdmin()
        || canManageClub(resource.data.clubId)
        || resource.data.createdBy == myUid();
    }

    // ═══ /match_lineups/{lineupId}  (id = {teamId}_{matchId}) ═══════
    // Compo spécifique d'un match (Phase 1A — 2026-05-23). Distincte de
    // la compo type saison (champ lineupTemplate du doc team). Chaque match
    // a SA propre compo, partagée avec tous les membres du club.
    //
    // Lecture : tout membre du club voit la compo du match.
    // Écriture : coach/owner/adjoint de l'équipe concernée.
    match /match_lineups/{lineupId} {
      allow read:   if isSignedIn() && canReadClub(resource.data.clubId);
      allow create: if isSignedIn()
        && canEditTeam(request.resource.data.clubId,
                       request.resource.data.teamId)
        && isString(request.resource.data.teamId)
        && isString(request.resource.data.matchId)
        && isString(request.resource.data.clubId)
        && lineupId == request.resource.data.teamId + '_' + request.resource.data.matchId
        && request.resource.data.size() <= 10;
      allow update: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.matchId == resource.data.matchId
        && request.resource.data.size() <= 10;
      allow delete: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId);
    }

    // ═══ /match_infos/{infoId}  (id = {teamId}_{matchId}) ════════════
    // Infos pratiques du match (stade, adresse, horaires RDV vs coup d'envoi,
    // covoiturage, notes libres) — 2026-05-24. Indispensables pour qu'une
    // convocation envoyée aux parents soit exploitable.
    //
    // Lecture : tout membre du club. Écriture : coach/owner/adjoint.
    match /match_infos/{infoId} {
      allow read:   if isSignedIn() && canReadClub(resource.data.clubId);
      allow create: if isSignedIn()
        && canEditTeam(request.resource.data.clubId,
                       request.resource.data.teamId)
        && isString(request.resource.data.teamId)
        && isString(request.resource.data.matchId)
        && isString(request.resource.data.clubId)
        && infoId == request.resource.data.teamId + '_' + request.resource.data.matchId
        && request.resource.data.size() <= 10;
      allow update: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.matchId == resource.data.matchId
        && request.resource.data.size() <= 10;
      allow delete: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId);
    }

    // ═══ /match_jerseys/{jerseyId}  (id = {teamId}_{matchId}) ════════
    // Numéros maillots match-specific (2026-05-24). Override des numéros
    // saison quand un joueur d'une autre catégorie dépanne ou que des
    // maillots ont changé pour ce match. doc.jerseys = { [pid]: num }.
    //
    // Lecture : tout membre du club. Écriture : coach/owner/adjoint.
    match /match_jerseys/{jerseyId} {
      allow read:   if isSignedIn() && canReadClub(resource.data.clubId);
      allow create: if isSignedIn()
        && canEditTeam(request.resource.data.clubId,
                       request.resource.data.teamId)
        && isString(request.resource.data.teamId)
        && isString(request.resource.data.matchId)
        && isString(request.resource.data.clubId)
        && jerseyId == request.resource.data.teamId + '_' + request.resource.data.matchId
        && request.resource.data.size() <= 10;
      allow update: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId)
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.matchId == resource.data.matchId
        && request.resource.data.size() <= 10;
      allow delete: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId);
    }

    // ═══ /coach_profiles/{uid} ═══════════════════════════════════════
    // Carte de visite partageable d'un coach (2026-05-24).
    // - Lecture PUBLIQUE : un parent / dirigeant peut consulter une fiche
    //   coach sans être connecté, via un lien ?coach=UID.
    // - Écriture : un user édite UNIQUEMENT son propre profil
    //   (request.auth.uid == uid). L'admin peut aussi modérer.
    //
    // Pas d'infos ultra-sensibles ici : le coach choisit ce qu'il rend
    // public (téléphone optionnel).
    match /coach_profiles/{uid} {
      allow read:   if true;
      allow create: if isSignedIn()
        && (isAdmin() || request.auth.uid == uid)
        && request.resource.data.uid == uid
        && request.resource.data.size() <= 14;
      allow update: if isSignedIn()
        && (isAdmin() || request.auth.uid == uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.size() <= 14;
      allow delete: if isSignedIn() && (isAdmin() || request.auth.uid == uid);
    }

    // ═══ /friendly_matches/{matchId}  (id = 'fr_<random>') ═══════════
    // Matchs amicaux hors-championnat (2026-05-24). Le calendrier FFF ne
    // liste que les matchs officiels — les amicaux (prépa, tournoi, jubilé…)
    // sont créés manuellement par le coach.
    //
    // Champs : { id, teamId, clubId, date, time, opponent, venue, isAmical }
    //
    // Lecture : tout membre du club. Écriture : coach/owner/adjoint.
    match /friendly_matches/{matchId} {
      allow read:   if isSignedIn() && canReadClub(resource.data.clubId);
      allow create: if isSignedIn()
        && canEditTeam(request.resource.data.clubId,
                       request.resource.data.teamId)
        && isString(request.resource.data.id)
        && isString(request.resource.data.teamId)
        && isString(request.resource.data.clubId)
        && matchId == request.resource.data.id
        && request.resource.data.size() <= 12;
      allow update: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.size() <= 12;
      allow delete: if isSignedIn()
        && canEditTeam(resource.data.clubId, resource.data.teamId);
    }

    // ═══════════════════════════════════════════════════════════════
    //  COLLECTIONS EXISTANTES — conservées telles quelles (ne pas casser)
    // ═══════════════════════════════════════════════════════════════

    // ─── /cdd_v2_players/{playerId} ────────────────────────────────
    // Statuts joueurs + métadonnées (blessure, suspension, indispo, etc.)
    match /cdd_v2_players/{playerId} {
      allow read: if true;

      allow create, update: if
        request.resource.data.keys().hasAll(['playerId','teamId','status'])
        && isString(request.resource.data.playerId)
        && isString(request.resource.data.teamId)
        && validStatus(request.resource.data.status)
        && strLen(request.resource.data.playerId, 80)
        && strLen(request.resource.data.teamId,   80)
        && request.resource.data.playerId == playerId
        && (!('statusMeta' in request.resource.data) || isMap(request.resource.data.statusMeta))
        && (!('statusUpdatedBy' in request.resource.data) || strLen(request.resource.data.statusUpdatedBy, 60));

      allow update: if request.resource.data.teamId == resource.data.teamId;
      allow delete: if false;
    }

    // ─── /cdd_v2_convoc/{matchId} ──────────────────────────────────
    match /cdd_v2_convoc/{matchId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['responses'])
        && (!('responses' in request.resource.data) || isMap(request.resource.data.responses));
    }

    // ─── /cdd_v2_votes/{matchId} ───────────────────────────────────
    match /cdd_v2_votes/{matchId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['voters'])
        && (!('voters' in request.resource.data) || isMap(request.resource.data.voters));
    }

    // ─── /cdd_v2_matches/{matchId} ─────────────────────────────────
    match /cdd_v2_matches/{matchId} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['id','teamA','teamB','status','events'])
        && request.resource.data.size() <= 50;
    }

    // ─── /shared_teams/{token} ─────────────────────────────────────
    match /shared_teams/{token} {
      allow read: if true;
      allow write: if
        request.resource.data.keys().hasAny(['payload'])
        && isMap(request.resource.data.payload)
        && isMap(request.resource.data.payload.team)
        && strLen(request.resource.data.payload.team.name, 200)
        && request.resource.data.size() <= 30;
    }

    // ─── Bloque tout le reste par défaut ───────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
