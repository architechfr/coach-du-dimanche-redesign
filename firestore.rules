//     return request.auth != null && (
//       isOwner()
//       || exists(/databases/$(database)/documents/cdd_v2_teams/$(teamId)/staff/$(request.auth.uid))
//     );
//   }
//
// Puis sur /cdd_v2_players/{playerId} :
//   allow create, update: if isCoach(request.resource.data.teamId) && [validations schéma...]
//   allow delete: if isOwner();
